---
// En-tête commun. `active` souligne la page courante ; `solid` force le fond
// crème (sous-pages) au lieu du header transparent posé sur le hero sombre.
interface Props {
  active?: "accueil" | "offres" | "realisations" | "contact";
  solid?: boolean;
}
const { active, solid = false } = Astro.props;

const links = [
  { key: "accueil", href: "/", label: "Accueil" },
  { key: "offres", href: "/offres", label: "Offres & tarifs" },
  { key: "realisations", href: "/realisations", label: "Réalisations" },
  { key: "contact", href: "/contact", label: "Contact" },
] as const;

const homeHref = active === "accueil" ? "#haut" : "/";
---
<header class:list={["site-header", { "header-solid": solid }]}>
  <div class="container header-inner">
    <a class="brand" href={homeHref} aria-label="LLWeb, accueil">
      <img class="brand-logo" src="/images/logo_complet.svg" alt="LLWeb" width="1662" height="946" />
    </a>

    <nav class="main-nav" id="menu" aria-label="Navigation principale">
      {links.map((l) => (
        <a
          href={l.key === "accueil" ? homeHref : l.href}
          aria-current={active === l.key ? "page" : undefined}
        >{l.label}</a>
      ))}
      <a class="btn btn-gold btn-sm nav-cta" href="/contact">Devis gratuit</a>
    </nav>

    <button class="nav-toggle" aria-expanded="false" aria-controls="menu" aria-label="Ouvrir le menu">
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
  </div>
</header>
