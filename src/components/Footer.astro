---
<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a class="brand brand-light" href="/" aria-label="LLWeb, accueil">
        <img class="brand-logo" src="/images/logo_complet.svg" alt="LLWeb" width="1662" height="946" />
      </a>
      <p>L'agence web des artisans, commerces, vignerons et producteurs, à Strasbourg, en Alsace et dans toute la France.</p>
    </div>

    <nav class="footer-nav" aria-label="Pied de page">
      <h4>Navigation</h4>
      <a href="/">Accueil</a>
      <a href="/offres">Offres &amp; tarifs</a>
      <a href="/portfolios">Portfolios</a>
      <a href="/realisations">Réalisations</a>
      <a href="/site-internet-vigneron-alsace">Sites pour vignerons</a>
      <a href="/contact">Contact</a>
    </nav>

    <div class="footer-contact">
      <h4>Contact</h4>
      <a href="mailto:contact@llweb.fr">contact@llweb.fr</a>
      <a href="tel:+33768785238">Léo · +33 (0)7 68 78 52 38</a>
      <a href="tel:+33685523631">Lukas · +33 (0)6 85 52 36 31</a>
      <button type="button" class="footer-link-btn"
              data-cal-namespace="appel-decouverte"
              data-cal-link="llweb/appel-decouverte"
              data-cal-config='{"layout":"month_view","theme":"light"}'>Réserver un appel</button>
      <p>Strasbourg, Alsace &amp; toute la France</p>
    </div>
  </div>
  <div class="container footer-bottom">
    <p>&copy; <span id="annee">2026</span> LLWeb. Tous droits réservés.</p>
    <p><a href="/mentions-legales">Mentions légales</a> · <a href="/confidentialite">Confidentialité</a></p>
  </div>
</footer>
