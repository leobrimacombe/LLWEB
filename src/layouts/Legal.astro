---
// Layout des pages légales : en-tête simplifié + contenu + pied minimal.
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonical: string;
  pageTitle: string;
  updated: string;
}
const { title, description, canonical, pageTitle, updated } = Astro.props;
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <meta name="theme-color" content="#3b0a14" />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/svg+xml" href="/images/favicon.svg?v=5" />
  <link rel="apple-touch-icon" href="/images/apple-touch-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Josefin+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

  <header class="subpage-header">
    <div class="container">
      <a class="brand" href="/" aria-label="LLWeb, accueil">
        <img class="brand-logo" src="/images/logo_complet.svg" alt="LLWeb" width="1662" height="946" />
      </a>
      <a class="back-home" href="/">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5m6-6-6 6 6 6"/></svg>
        Retour à l'accueil
      </a>
    </div>
  </header>

  <main class="container legal">
    <h1>{pageTitle}</h1>
    <p class="legal-date">Dernière mise à jour : {updated}</p>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container footer-bottom">
      <p>&copy; 2026 LLWeb. Tous droits réservés.</p>
      <p>
        <a href="/">Accueil</a> ·
        <a href="/mentions-legales">Mentions légales</a> ·
        <a href="/confidentialite">Confidentialité</a>
      </p>
    </div>
  </footer>

</body>
</html>
