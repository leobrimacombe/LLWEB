---
import Base from "../layouts/Base.astro";
---
<Base
  title="Réalisations & démo | LLWeb, agence web à Strasbourg"
  description="Découvrez notre savoir-faire : un site de démonstration complet conçu de A à Z, à explorer librement. Le soin que nous mettrons dans votre projet."
  canonical="https://llweb.fr/realisations.html"
  ogTitle="Réalisations & démo | LLWeb"
  ogDescription="Un site de démonstration complet conçu de A à Z, à explorer librement."
  active="realisations"
  solid
>
  <!-- ============ BANDEAU DE PAGE ============ -->
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow eyebrow-gold">Réalisations</p>
      <h1>La preuve par l'exemple</h1>
      <p>
        LLWeb est une jeune agence : plutôt que d'aligner des logos de clients,
        nous préférons vous montrer concrètement notre travail.
      </p>
    </div>
  </section>

  <!-- ============ DÉMONSTRATION ============ -->
  <section class="section" id="realisations" aria-labelledby="realisations-titre">
    <div class="container">
      <header class="section-head reveal">
        <p class="eyebrow">Démonstration</p>
        <h2 id="realisations-titre">Le Domaine Vogel-Stein, notre site témoin</h2>
        <p class="section-intro">
          Un site de démonstration conçu de A à Z pour un domaine viticole
          imaginaire, avec le soin exact que nous mettrons dans le vôtre,
          quel que soit votre métier. Cliquez sur une capture pour l'explorer.
        </p>
      </header>

      <div class="showcase">
        <a class="shot shot-main reveal" href="https://vindemo.vercel.app/" target="_blank" rel="noopener">
          <span class="shot-chrome" aria-hidden="true"><i></i><i></i><i></i><em>vindemo.vercel.app</em></span>
          <span class="shot-media">
            <img src="images/demo-accueil.jpg" alt="Page d'accueil du site de démonstration : Domaine Vogel-Stein, vignoble au coucher de soleil" width="1200" height="759" loading="lazy" />
          </span>
          <span class="shot-caption">
            <strong>Un accueil qui raconte</strong>
            Une page immersive qui met en valeur votre histoire et votre univers.
          </span>
        </a>

        <a class="shot reveal" href="https://vindemo.vercel.app/boutique" target="_blank" rel="noopener">
          <span class="shot-chrome" aria-hidden="true"><i></i><i></i><i></i><em>vindemo.vercel.app/boutique</em></span>
          <span class="shot-media">
            <img src="images/demo-boutique.jpg" alt="Boutique en ligne du site de démonstration, verres de dégustation" width="1000" height="633" loading="lazy" />
          </span>
          <span class="shot-caption">
            <strong>Vente en direct</strong>
            Une boutique intégrée pour vendre vos produits sans intermédiaire.
          </span>
        </a>

        <a class="shot shot-phone reveal" href="https://vindemo.vercel.app/" target="_blank" rel="noopener">
          <span class="shot-media">
            <img src="images/demo-mobile.jpg" alt="Version mobile du site de démonstration" width="480" height="1039" loading="lazy" />
          </span>
          <span class="shot-caption">
            <strong>Impeccable sur mobile</strong>
            Pensé pour le téléphone et bien référencé sur Google.
          </span>
        </a>
      </div>

      <div class="demo-cta-row reveal">
        <a class="btn btn-wine" href="https://vindemo.vercel.app/" target="_blank" rel="noopener">
          Explorer le site de démo
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 4h6v6M20 4l-9 9M19 13v6a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1h6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ ET VOTRE PROJET ============ -->
  <section class="section section-dark" aria-labelledby="cta-titre">
    <div class="container narrow center">
      <p class="eyebrow eyebrow-gold reveal">Votre projet ici&nbsp;?</p>
      <h2 id="cta-titre" class="closing-title reveal">Votre site pourrait être le prochain</h2>
      <p class="closing-lead reveal">
        Cette page accueillera bientôt nos réalisations clientes. La vôtre,
        peut-être&nbsp;: profitez de nos tarifs de lancement.
      </p>
      <div class="cta-row reveal">
        <a class="btn btn-gold" href="contact.html">Demander un devis gratuit</a>
        <a class="btn btn-ghost" href="offres.html">Voir les tarifs</a>
      </div>
    </div>
  </section>
</Base>
